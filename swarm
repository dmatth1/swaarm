#!/usr/bin/env bash
# swarm - Multi-agent AI task execution framework
# Inspired by Anthropic's multi-agent C compiler project
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPTS_DIR="$SCRIPT_DIR/prompts"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log()     { echo -e "${BLUE}[swarm]${NC} $*"; }
success() { echo -e "${GREEN}[swarm ✓]${NC} $*"; }
warn()    { echo -e "${YELLOW}[swarm !]${NC} $*"; }
error()   { echo -e "${RED}[swarm ✗]${NC} $*" >&2; }
info()    { echo -e "${CYAN}        ${NC} $*"; }

# Defaults
NUM_AGENTS=3
OUTPUT_DIR=""
TASK=""
VERBOSE=false
MAX_WORKER_ITERATIONS=100
DOCKER_IMAGE="swarm-agent"
MODEL=""
REMOTE_REPO=""  # GitHub URL — if set, repo.git mirrors to this remote
RUN_ID=""
EXTRA_MOUNTS=()  # additional -v host:container mounts passed to every container

usage() {
    cat <<'EOF'
swarm — Multi-agent AI task execution framework

Usage:
  swarm "<prompt>" [OPTIONS]

Arguments:
  prompt            What to build, or additional guidance for an existing run
                    (optional when resuming with -o)

Options:
  -n, --agents N        Number of parallel worker agents (default: 3)
  -o, --output DIR      Output directory (new run if absent, resume if exists)
  -v, --verbose         Show agent output in real-time
  --model MODEL         Claude model to use (e.g. opus, sonnet, opus[1m])
  --repo URL            Push to a remote GitHub repo (e.g. https://github.com/user/repo)
  --mount HOST:CONTAINER  Mount additional host directory into every container (repeatable)
  --max-iterations N    Max Claude invocations per worker, excluding waits (default: 100)
  -h, --help            Show this help

Subcommands:
  swarm status <output-dir>           Show live status of a running swarm
  swarm kill <output-dir> [agent-id]  Kill all agents or a specific one
  swarm logs <output-dir> [agent]     Tail agent logs in real-time
  swarm cleanup [output-dir]          Remove orphaned containers (all runs, or specific run)

Examples:
  # New run (creates swarm-TIMESTAMP/)
  swarm "Build a REST API for a todo app with SQLite"
  swarm "Create a Python CLI" --agents 2 --model opus

  # Resume existing run (no new guidance)
  swarm -o ./swarm-20240115-143022

  # Resume with new guidance
  swarm "Also add rate limiting" -o ./swarm-20240115-143022

  # Resume with different agent count
  swarm "Fix the failing tests" -o ./swarm-20240115-143022 -n 5

Output:
  swarm-TIMESTAMP/
  ├── main/        ← Your project lives here
  ├── logs/        ← Agent logs for debugging
  └── repo.git/    ← Shared coordination repo
EOF
}

# ─────────────────────────────────────────────────────────────
# SUBCOMMANDS
# ─────────────────────────────────────────────────────────────

cmd_status() {
    local output_dir="${1:-}"
    if [[ -z "$output_dir" ]]; then
        error "Usage: swarm status <output-dir>"
        exit 1
    fi
    if [[ ! -d "$output_dir/main/tasks" ]]; then
        error "Not a swarm output directory: $output_dir"
        exit 1
    fi

    # Pull latest state
    (cd "$output_dir/main" && git pull origin main -q 2>/dev/null) || true

    local n_pending n_active n_done
    n_pending=$(find "$output_dir/main/tasks/pending" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    n_active=$(find "$output_dir/main/tasks/active"  -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    n_done=$(find "$output_dir/main/tasks/done"    -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)

    # Read task description from SPEC.md if available
    local task_desc=""
    if [[ -f "$output_dir/main/SPEC.md" ]]; then
        task_desc=$(grep -m1 '^\*\*Task:\*\*' "$output_dir/main/SPEC.md" 2>/dev/null | sed 's/\*\*Task:\*\* //' || true)
    fi

    echo
    echo -e "${CYAN}${BOLD}Swarm Status: $output_dir${NC}"
    if [[ -n "$task_desc" ]]; then
        echo -e "   Task:    $task_desc"
    fi
    echo
    echo -e "Tasks:    ${GREEN}${n_done} done${NC} | ${YELLOW}${n_active} active${NC} | ${BLUE}${n_pending} pending${NC}"

    # Worker status
    local pids_dir="$output_dir/pids"
    local worker_status_line=""
    local worker_num=1
    while true; do
        local wlog="$output_dir/logs/worker-${worker_num}.log"
        if [[ ! -f "$wlog" ]]; then
            break
        fi
        local wstatus=""
        local cid_file="$pids_dir/worker-${worker_num}.cid"
        if [[ -f "$cid_file" ]]; then
            local wcname
            wcname=$(cat "$cid_file" 2>/dev/null || echo "")
            if [[ -n "$wcname" ]] && docker inspect --format='{{.State.Running}}' "$wcname" 2>/dev/null | grep -q true; then
                wstatus="${GREEN}RUNNING (container)${NC}"
            else
                wstatus="${YELLOW}STOPPED${NC}"
            fi
        elif grep -q "DONE at" "$wlog" 2>/dev/null; then
            wstatus="${GREEN}DONE${NC}"
        else
            wstatus="${YELLOW}UNKNOWN${NC}"
        fi
        if [[ -n "$worker_status_line" ]]; then
            worker_status_line="$worker_status_line | worker-${worker_num} $wstatus"
        else
            worker_status_line="worker-${worker_num} $wstatus"
        fi
        worker_num=$((worker_num + 1))
    done
    if [[ -n "$worker_status_line" ]]; then
        echo -e "Workers:  $worker_status_line"
    fi

    # Active tasks
    if [[ "$n_active" -gt 0 ]]; then
        echo
        echo "Active tasks:"
        local active_file
        for active_file in "$output_dir/main/tasks/active"/worker-*.md; do
            if [[ -f "$active_file" ]]; then
                local fname
                fname=$(basename "$active_file")
                # fname pattern: worker-N--NNN-taskname.md
                local wid taskname
                wid=$(echo "$fname" | sed 's/worker-\([^-]*\)--.*/\1/')
                taskname=$(echo "$fname" | sed 's/worker-[^-]*--//')
                echo "  worker-${wid}: $taskname"
            fi
        done
    fi

    # Done tasks
    if [[ "$n_done" -gt 0 ]]; then
        echo
        echo "Done:"
        local done_file
        for done_file in "$output_dir/main/tasks/done"/*.md; do
            if [[ -f "$done_file" ]]; then
                echo "  $(basename "$done_file")"
            fi
        done
    fi

    echo
}

cmd_logs() {
    local output_dir="${1:-}"
    local target="${2:-}"

    if [[ -z "$output_dir" ]]; then
        error "Usage: swarm logs <output-dir> [worker-N | orchestrator | all]"
        exit 1
    fi

    local logs_dir="$output_dir/logs"
    if [[ ! -d "$logs_dir" ]]; then
        error "No logs directory found: $logs_dir"
        exit 1
    fi

    if [[ -z "$target" || "$target" == "all" ]]; then
        # Tail all log files
        local log_files=()
        for f in "$logs_dir"/*.log; do
            [[ -f "$f" ]] && log_files+=("$f")
        done
        if [[ "${#log_files[@]}" -eq 0 ]]; then
            error "No log files found in $logs_dir"
            exit 1
        fi
        info "Tailing ${#log_files[@]} log file(s) — Ctrl-C to stop"
        echo
        tail -f "${log_files[@]}"
    else
        local log_file="$logs_dir/${target}.log"
        if [[ ! -f "$log_file" ]]; then
            error "Log file not found: $log_file"
            info "Available logs:"
            ls "$logs_dir"/*.log 2>/dev/null | xargs -I{} basename {} | sed 's/\.log$//' | sed 's/^/  /'
            exit 1
        fi
        info "Tailing $log_file — Ctrl-C to stop"
        echo
        tail -f "$log_file"
    fi
}

cmd_kill() {
    local output_dir="${1:-}"
    local target="${2:-}"

    if [[ -z "$output_dir" ]]; then
        error "Usage: swarm kill <output-dir> [agent-id]"
        exit 1
    fi

    local pids_dir="$output_dir/pids"
    if [[ ! -d "$pids_dir" ]]; then
        error "No pids directory found in: $output_dir"
        exit 1
    fi

    if [[ -n "$target" ]]; then
        # Kill specific target — container only
        local cid_file="$pids_dir/${target}.cid"
        if [[ -f "$cid_file" ]]; then
            local cname
            cname=$(cat "$cid_file" 2>/dev/null || echo "")
            if [[ -n "$cname" ]]; then
                docker stop "$cname" 2>/dev/null || true
                docker rm "$cname" 2>/dev/null || true
                rm -f "$cid_file"
                success "Stopped $target (container $cname)"
            fi
        else
            error "No tracking file found for: $target"
            exit 1
        fi
    else
        # Kill all — containers
        local cid_file cname name
        for cid_file in "$pids_dir"/*.cid; do
            if [[ -f "$cid_file" ]]; then
                name=$(basename "$cid_file" .cid)
                cname=$(cat "$cid_file" 2>/dev/null || echo "")
                if [[ -n "$cname" ]]; then
                    docker stop "$cname" 2>/dev/null || true
                    docker rm "$cname" 2>/dev/null || true
                    success "Stopped $name (container $cname)"
                fi
                rm -f "$cid_file"
            fi
        done
    fi
}

cmd_cleanup() {
    local output_dir="${1:-}"
    if ! command -v docker &>/dev/null; then
        error "Docker not found"
        exit 1
    fi

    local filter containers
    if [[ -n "$output_dir" ]]; then
        local run_id
        run_id=$(basename "$output_dir")
        filter="name=swarm-${run_id}-"
        log "Cleaning up containers for run: $run_id"
    else
        filter="name=swarm-"
        log "Cleaning up all swarm containers..."
    fi

    containers=$(docker ps -aq --filter "$filter" 2>/dev/null)
    if [[ -n "$containers" ]]; then
        echo "$containers" | xargs docker stop 2>/dev/null || true
        echo "$containers" | xargs docker rm 2>/dev/null || true
        success "Done"
    else
        log "No swarm containers found"
    fi
}

cmd_resume() {
    local output_dir="${1:-}"
    local override_agents="${2:-}"
    local override_model="${3:-}"
    local override_repo="${4:-}"

    if [[ -z "$output_dir" ]]; then
        error "Usage: swarm resume <output-dir> [-n N] [--model M] [--repo URL]"
        exit 1
    fi
    if [[ ! -d "$output_dir/main/tasks" ]]; then
        error "Not a swarm output directory: $output_dir"
        exit 1
    fi

    local state_file="$output_dir/swarm.state"
    if [[ ! -f "$state_file" ]]; then
        error "No state file found: $state_file"
        info "To resume manually: move tasks/active/*.md back to tasks/pending/ and re-run workers"
        exit 1
    fi

    # shellcheck source=/dev/null
    source "$state_file"  # sets SWARM_TASK, SWARM_AGENTS, SWARM_MODEL

    local agents="${override_agents:-$SWARM_AGENTS}"
    MODEL="${override_model:-${SWARM_MODEL:-}}"
    REMOTE_REPO="${override_repo:-${SWARM_REPO:-}}"

    OUTPUT_DIR="$(cd "$output_dir" && pwd)"
    REPO_DIR="$OUTPUT_DIR/repo.git"
    LOGS_DIR="$OUTPUT_DIR/logs"
    MAIN_DIR="$OUTPUT_DIR/main"

    # Ensure github remote is configured if --repo was provided (new or resumed)
    if [[ -n "$REMOTE_REPO" && -d "$REPO_DIR" ]]; then
        (cd "$REPO_DIR" && git remote get-url github 2>/dev/null) || \
            (cd "$REPO_DIR" && git remote add github "$REMOTE_REPO") || true
    fi

    echo
    echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║       🐝  SWARM RESUME  🐝               ║${NC}"
    echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
    echo
    info "Task:   $SWARM_TASK"
    info "Agents: $agents"
    [[ -n "$MODEL" ]] && info "Model:  $MODEL"
    [[ -n "$REMOTE_REPO" ]] && info "Repo:   $REMOTE_REPO"
    info "Output: $OUTPUT_DIR"
    echo

    # Pull latest state
    (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

    # Return any stuck tasks (worker-N--NNN-task.md) back to pending
    local unstick_dir
    unstick_dir=$(mktemp -d)
    git clone "$REPO_DIR" "$unstick_dir" -q 2>/dev/null
    (
        cd "$unstick_dir"
        git config user.email "swarm@local"
        git config user.name "Swarm Resume"
        local any_moved=false
        for sf in tasks/active/worker-*.md; do
            if [[ -f "$sf" ]]; then
                local tname
                tname=$(basename "$sf" | sed 's/worker-[^-]*--//')
                log "  Returning stuck task: $tname"
                mv "$sf" "tasks/pending/$tname"
                any_moved=true
            fi
        done
        if [[ "$any_moved" == "true" ]]; then
            git add -A
            git commit -m "resume: return stuck tasks to pending" -q
            git push origin main -q
        fi
    )
    rm -rf "$unstick_dir"

    # Sync main view
    (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

    local pending done_n
    pending=$(find "$MAIN_DIR/tasks/pending" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    done_n=$(find "$MAIN_DIR/tasks/done" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)

    success "$pending task(s) pending, $done_n done — spawning $agents worker(s)"
    echo

    # Pre-flight specialist sweep before re-spawning workers
    _g_specialist_count=0
    run_specialist_sweep "pre-flight-resume"
    sync_main
    echo

    # Spawn workers
    RUN_ID="$(basename "$OUTPUT_DIR")"
    ensure_docker_image
    trap cleanup_docker EXIT
    run_with_review "$agents"

    # Final sync
    (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

    local total_done total_pending total_active
    total_done=$(find "$MAIN_DIR/tasks/done" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    total_pending=$(find "$MAIN_DIR/tasks/pending" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    total_active=$(find "$MAIN_DIR/tasks/active" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0)

    echo
    success "Tasks completed: $total_done"
    if [[ "$total_pending" -gt 0 ]]; then warn "Tasks incomplete: $total_pending"; fi
    if [[ "$total_active"  -gt 0 ]]; then warn "Tasks stuck:      $total_active (run resume again)"; fi
    echo
    info "Project files: $MAIN_DIR/"
    info "Agent logs:    $LOGS_DIR/"
    echo

    if [[ "${failed:-0}" -gt 0 ]]; then warn "${failed} worker(s) exited with errors (check logs)"; fi
}


# ─────────────────────────────────────────────────────────────
# DOCKER HELPERS
# ─────────────────────────────────────────────────────────────

get_claude_oauth_token() {
    # Extract OAuth access token for injection into Docker containers
    local creds
    if [[ "$(uname)" == "Darwin" ]]; then
        # macOS: read from Keychain
        creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 1
    else
        # Linux: read from ~/.claude/credentials.json
        local creds_file="$HOME/.claude/credentials.json"
        [[ -f "$creds_file" ]] || return 1
        creds=$(cat "$creds_file")
    fi
    echo "$creds" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['claudeAiOauth']['accessToken'])" 2>/dev/null
}

ensure_docker_image() {
    if docker image inspect "$DOCKER_IMAGE" &>/dev/null; then
        log "Docker image '$DOCKER_IMAGE' found"
        return 0
    fi
    log "Building Docker image '$DOCKER_IMAGE' (first run only)..."
    docker build -t "$DOCKER_IMAGE" "$SCRIPT_DIR"
}

docker_run_orchestrator() {
    local next_task_num="${1:-}"

    log "Starting orchestrator container..."

    local container_name="swarm-${RUN_ID}-orchestrator"

    if [[ -n "$next_task_num" ]]; then
        log "Orchestrator augmenting existing project (new tasks start at $(printf '%03d' "$next_task_num"))..."
    else
        log "Orchestrator analyzing task and creating subtasks..."
    fi

    local oauth_token
    oauth_token=$(get_claude_oauth_token) || true

    local extra_vol_flags=()
    for _m in "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}"; do extra_vol_flags+=(-v "$_m"); done

    docker run --rm \
        --name "$container_name" \
        -v "$REPO_DIR:/upstream" \
        -v "$LOGS_DIR:/logs" \
        -v "$PROMPTS_DIR:/prompts:ro" \
        "${extra_vol_flags[@]+"${extra_vol_flags[@]}"}" \
        ${oauth_token:+-e CLAUDE_CODE_OAUTH_TOKEN="$oauth_token"} \
        -e TASK="$TASK" \
        -e VERBOSE="$VERBOSE" \
        ${next_task_num:+-e NEXT_TASK_NUM="$next_task_num"} \
        ${MODEL:+-e MODEL="$MODEL"} \
        ${REMOTE_REPO:+-e PUBLIC_REPO=true} \
        "$DOCKER_IMAGE" \
        orchestrator || true

    # Sync to see what was created
    sync_main

    local tasks
    tasks=$(pending_count)

    if [[ "$tasks" -gt 0 ]]; then
        success "Orchestrator created $tasks tasks"
        if [[ "$VERBOSE" == "true" ]]; then
            log "Tasks:"
            ls "$MAIN_DIR/tasks/pending/" | sed 's/^/    /'
        fi
        return 0
    else
        error "Orchestrator failed to create tasks. Check: $LOGS_DIR/orchestrator.log"
        if [[ -f "$LOGS_DIR/orchestrator.log" ]]; then
            if grep -qi "error\|failed\|exception" "$LOGS_DIR/orchestrator.log" 2>/dev/null; then
                tail -20 "$LOGS_DIR/orchestrator.log" >&2
            fi
        fi
        return 1
    fi
}


docker_run_worker() {
    local agent_id="$1"
    local auto_rm="${2:-false}"
    local container_name="swarm-${RUN_ID}-worker-${agent_id}"

    local prompt_file="$LOGS_DIR/worker-$agent_id-prompt.md"
    sed "s|{{AGENT_ID}}|worker-$agent_id|g" "$PROMPTS_DIR/worker.md" > "$prompt_file"

    local oauth_token
    oauth_token=$(get_claude_oauth_token) || true

    local extra_flags=()
    [[ "$auto_rm" == "true" ]] && extra_flags+=("--rm")
    for _m in "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}"; do extra_flags+=(-v "$_m"); done

    docker run -d \
        "${extra_flags[@]+"${extra_flags[@]}"}" \
        --name "$container_name" \
        -v "$REPO_DIR:/upstream" \
        -v "$LOGS_DIR:/logs" \
        -v "$PROMPTS_DIR:/prompts:ro" \
        ${oauth_token:+-e CLAUDE_CODE_OAUTH_TOKEN="$oauth_token"} \
        -e AGENT_ID="worker-$agent_id" \
        -e VERBOSE="$VERBOSE" \
        -e MAX_WORKER_ITERATIONS="$MAX_WORKER_ITERATIONS" \
        -e MULTI_ROUND=true \
        ${MODEL:+-e MODEL="$MODEL"} \
        ${REMOTE_REPO:+-e PUBLIC_REPO=true} \
        "$DOCKER_IMAGE" \
        worker "$agent_id" > /dev/null

    # Track container for kill/status
    mkdir -p "$OUTPUT_DIR/pids"
    echo "$container_name" > "$OUTPUT_DIR/pids/worker-${agent_id}.cid"
}

docker_run_reviewer() {
    local task_name="$1"
    local review_num="$2"
    local container_name="swarm-${RUN_ID}-reviewer-${review_num}"

    local oauth_token
    oauth_token=$(get_claude_oauth_token) || true

    local extra_vol_flags=()
    for _m in "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}"; do extra_vol_flags+=(-v "$_m"); done

    docker run --rm \
        --name "$container_name" \
        -v "$REPO_DIR:/upstream" \
        -v "$LOGS_DIR:/logs" \
        -v "$PROMPTS_DIR:/prompts:ro" \
        "${extra_vol_flags[@]+"${extra_vol_flags[@]}"}" \
        ${oauth_token:+-e CLAUDE_CODE_OAUTH_TOKEN="$oauth_token"} \
        -e COMPLETED_TASK="$task_name" \
        -e REVIEW_NUM="$review_num" \
        -e VERBOSE="$VERBOSE" \
        ${MODEL:+-e MODEL="$MODEL"} \
        ${REMOTE_REPO:+-e PUBLIC_REPO=true} \
        "$DOCKER_IMAGE" \
        reviewer || true
}

# Compute the next available task number across pending/active/done directories.
compute_next_task_num() {
    local max_num=0 f num
    for f in "$MAIN_DIR/tasks/pending/"*.md \
              "$MAIN_DIR/tasks/active/"*.md \
              "$MAIN_DIR/tasks/done/"*.md; do
        [[ -f "$f" ]] || continue
        num=$(basename "$f" | grep -o '^[0-9]*' || echo 0)
        num=$((10#$num))
        [[ "$num" -gt "$max_num" ]] && max_num="$num"
    done
    echo $(( max_num + 1 ))
}

docker_run_specialist() {
    local specialist_name="$1"
    local specialist_role="$2"
    local specialist_num="$3"
    local container_name="swarm-${RUN_ID}-specialist-${specialist_name}-${specialist_num}"

    local oauth_token
    oauth_token=$(get_claude_oauth_token) || true

    local extra_vol_flags=()
    for _m in "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}"; do extra_vol_flags+=(-v "$_m"); done

    docker run --rm \
        --name "$container_name" \
        -v "$REPO_DIR:/upstream" \
        -v "$LOGS_DIR:/logs" \
        -v "$PROMPTS_DIR:/prompts:ro" \
        "${extra_vol_flags[@]+"${extra_vol_flags[@]}"}" \
        ${oauth_token:+-e CLAUDE_CODE_OAUTH_TOKEN="$oauth_token"} \
        -e SPECIALIST_NAME="$specialist_name" \
        -e SPECIALIST_ROLE="$specialist_role" \
        -e SPECIALIST_NUM="$specialist_num" \
        -e VERBOSE="$VERBOSE" \
        ${MODEL:+-e MODEL="$MODEL"} \
        ${REMOTE_REPO:+-e PUBLIC_REPO=true} \
        "$DOCKER_IMAGE" \
        specialist || true
}

# Run all specialists defined in SPEC.md ## Specialists section.
# Uses global _g_specialist_count (set by caller before invoking).
run_specialist_sweep() {
    local sweep_label="$1"

    # Parse specialist names from SPEC.md (after ## Specialists, ### Name lines)
    local spec_names
    spec_names=$(awk '/^## Specialists/{found=1; next} found && /^## [^#]/{exit} found && /^### /{sub(/^### /,""); print}' \
        "$MAIN_DIR/SPEC.md" 2>/dev/null) || true

    [[ -z "$spec_names" ]] && return 0

    # Collect specialists to run
    local -a specialist_names=()
    local -a specialist_roles=()
    local -a specialist_nums=()
    local sname
    while IFS= read -r sname; do
        [[ -z "$sname" ]] && continue
        local srole
        srole=$(awk -v name="$sname" '$0 == "### " name {found=1; next} found && /^### /{exit} found && NF{print}' \
            "$MAIN_DIR/SPEC.md" 2>/dev/null) || true
        [[ -z "$srole" ]] && continue

        _g_specialist_count=$(( _g_specialist_count + 1 ))
        specialist_names+=("$sname")
        specialist_roles+=("$srole")
        specialist_nums+=("$_g_specialist_count")
    done <<< "$spec_names"

    local count="${#specialist_names[@]}"
    [[ "$count" -eq 0 ]] && return 0

    log "Running specialist sweep: ${sweep_label} ($count specialist(s) in parallel)"

    # Launch all specialists in parallel
    local -a pids=()
    local i
    for i in $(seq 0 $(( count - 1 ))); do
        log "  Specialist: ${specialist_names[$i]}"
        docker_run_specialist "${specialist_names[$i]}" "${specialist_roles[$i]}" "${specialist_nums[$i]}" &
        pids+=($!)
    done

    # Wait for all to finish
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    sync_main
}

check_and_respawn_dead_workers() {
    local agents="$1"
    local i
    for i in $(seq 1 "$agents"); do
        local cid_file="$OUTPUT_DIR/pids/worker-${i}.cid"
        [[ -f "$cid_file" ]] || continue
        local cname
        cname=$(cat "$cid_file" 2>/dev/null) || continue
        [[ -z "$cname" ]] && continue

        # "gone" covers both removed-by---rm and inspect failure
        local running
        running=$(docker inspect --format='{{.State.Running}}' "$cname" 2>/dev/null) || running="gone"
        [[ "$running" == "true" ]] && continue

        # Container is not running — check for tasks it left in active/
        local stuck_count=0
        local task_file
        for task_file in "$MAIN_DIR/tasks/active/worker-${i}--"*.md; do
            [[ -f "$task_file" ]] && stuck_count=$((stuck_count + 1))
        done

        if [[ "$stuck_count" -gt 0 ]]; then
            log "Worker $i died with $stuck_count stuck task(s) — unsticking..."
            local tmp
            tmp=$(mktemp -d)
            git clone "$REPO_DIR" "$tmp" -q 2>/dev/null
            (
                cd "$tmp"
                git config user.email "swarm@local"
                git config user.name "Swarm Harness"
                local moved=false
                local sf
                for sf in tasks/active/worker-${i}--*.md; do
                    [[ -f "$sf" ]] || continue
                    local tname
                    tname=$(basename "$sf" | sed "s/worker-${i}--//")
                    mv "$sf" "tasks/pending/$tname"
                    moved=true
                done
                if [[ "$moved" == "true" ]]; then
                    git add -A
                    git commit -m "harness: unstick worker-${i} tasks after crash" -q
                    git push origin main -q
                fi
            )
            rm -rf "$tmp"
            sync_main
        fi

        # Clean up stale tracking file
        docker rm "$cname" 2>/dev/null || true
        rm -f "$cid_file"

        # Respawn if there is still pending work (cap attempts to prevent infinite loops)
        local p
        p=$(pending_count)
        if [[ "$p" -gt 0 ]]; then
            local respawn_file="$OUTPUT_DIR/pids/worker-${i}.respawns"
            local respawns=0
            [[ -f "$respawn_file" ]] && respawns=$(cat "$respawn_file" 2>/dev/null || echo 0)
            local max_respawns="${MAX_RESPAWNS:-5}"
            if [[ "$respawns" -ge "$max_respawns" ]]; then
                warn "Worker $i hit respawn cap ($max_respawns) — not respawning (possible persistent failure)"
            else
                respawns=$((respawns + 1))
                echo "$respawns" > "$respawn_file"
                log "Respawning worker $i (attempt $respawns/$max_respawns)..."
                docker_run_worker "$i" "true"
            fi
        fi
    done
}

run_with_review() {
    local agents="$1"

    # Spawn all workers in background (MULTI_ROUND=true set in docker_run_worker)
    log "Spawning $agents worker agents..."
    for i in $(seq 1 "$agents"); do
        docker_run_worker "$i" "true"
        sleep 1
    done
    echo

    monitor_progress &
    local monitor_pid=$!

    local reviewed=()
    local blocked_handled=()
    local review_count=0
    # _g_specialist_count is NOT reset here — it may already be non-zero from a
    # pre-flight sweep run before workers started; preserve continuity of numbering.
    local max_reviews=$(( MAX_WORKER_ITERATIONS * agents ))
    local all_complete=false
    local stuck_cycles=0
    local max_stuck_cycles=3
    local last_restructure_at=0
    local restructure_interval="${RESTRUCTURE_INTERVAL:-6}"

    while [[ "$all_complete" == "false" ]]; do
        sleep 5
        sync_main

        # Detect and recover dead workers before scanning for work
        check_and_respawn_dead_workers "$agents"

        local new_reviews_this_cycle=0

        # Scan done/ for unreviewed tasks — run test suite after each completion
        local task_file task_name
        for task_file in "$MAIN_DIR/tasks/done/"*.md; do
            [[ -f "$task_file" ]] || continue
            task_name=$(basename "$task_file")
            [[ "$task_name" == ".gitkeep" ]] && continue

            # Skip already-reviewed tasks
            local already_reviewed=false
            local r
            for r in "${reviewed[@]+"${reviewed[@]}"}"; do
                if [[ "$r" == "$task_name" ]]; then
                    already_reviewed=true
                    break
                fi
            done
            [[ "$already_reviewed" == "true" ]] && continue

            review_count=$((review_count + 1))
            new_reviews_this_cycle=$((new_reviews_this_cycle + 1))

            if [[ "$review_count" -gt "$max_reviews" ]]; then
                warn "Max reviews ($max_reviews) reached — forcing stop"
                all_complete=true
                break
            fi

            log "Running reviewer ${review_count} for: $task_name"
            docker_run_reviewer "$task_name" "$review_count"
            reviewed+=("$task_name")

            # If tests failed, trigger orchestrator immediately to add fix tasks
            if grep -q "TESTS_FAIL" "$LOGS_DIR/reviewer-${review_count}.log" 2>/dev/null; then
                log "Tests failing after ${task_name} — triggering orchestrator to add fix tasks"
                local next_num
                next_num=$(compute_next_task_num)
                docker_run_orchestrator "$next_num"
            fi
        done

        # Reset respawn counters when progress is made (prevents stale caps after recovery)
        if [[ "$new_reviews_this_cycle" -gt 0 ]]; then
            rm -f "$OUTPUT_DIR/pids/"worker-*.respawns 2>/dev/null
        fi

        # Scan pending/ for BLOCKED tasks — orchestrator decomposes, hints, or escalates
        if [[ "$all_complete" == "false" ]]; then
            for task_file in "$MAIN_DIR/tasks/pending/BLOCKED-"*.md; do
                [[ -f "$task_file" ]] || continue
                task_name=$(basename "$task_file")

                local already_blocked_handled=false
                local bh
                for bh in "${blocked_handled[@]+"${blocked_handled[@]}"}"; do
                    [[ "$bh" == "$task_name" ]] && already_blocked_handled=true && break
                done
                [[ "$already_blocked_handled" == "true" ]] && continue

                review_count=$((review_count + 1))
                new_reviews_this_cycle=$((new_reviews_this_cycle + 1))

                if [[ "$review_count" -gt "$max_reviews" ]]; then
                    warn "Max reviews ($max_reviews) reached — forcing stop"
                    all_complete=true
                    break
                fi

                log "Blocked task detected: ${task_name} — triggering orchestrator (${review_count})..."
                local next_num
                next_num=$(compute_next_task_num)
                docker_run_orchestrator "$next_num"
                blocked_handled+=("$task_name")
            done
        fi

        # Periodic orchestrator + specialist sweep (every N completions, concurrent with workers)
        if [[ "$all_complete" == "false" ]]; then
            local current_done
            current_done=$(done_count)
            if [[ "$current_done" -ge $(( last_restructure_at + restructure_interval )) && "$current_done" -gt 0 ]]; then
                last_restructure_at="$current_done"

                review_count=$((review_count + 1))
                log "Running periodic orchestrator at $current_done tasks (${review_count})..."
                local next_num
                next_num=$(compute_next_task_num)
                docker_run_orchestrator "$next_num"

                run_specialist_sweep "at ${current_done} tasks"
            fi
        fi

        # Final-drain / stuck-state check: no new reviews this cycle
        if [[ "$all_complete" == "false" && "$new_reviews_this_cycle" -eq 0 ]]; then
            local p_count a_count
            p_count=$(pending_count)
            a_count=$(active_count)
            if [[ "$p_count" -eq 0 && "$a_count" -eq 0 ]]; then
                # Queue fully drained — final specialist sweep then test confirmation
                stuck_cycles=0
                run_specialist_sweep "final"
                review_count=$((review_count + 1))
                if [[ "$review_count" -gt "$max_reviews" ]]; then
                    warn "Max reviews ($max_reviews) reached — forcing stop"
                    all_complete=true
                else
                    log "Running final test review (${review_count})..."
                    docker_run_reviewer "--final--" "$review_count"
                    if grep -q "TESTS_PASS" "$LOGS_DIR/reviewer-${review_count}.log" 2>/dev/null; then
                        log "Tests passing and queue empty — project complete"
                        all_complete=true
                    elif grep -q "TESTS_FAIL" "$LOGS_DIR/reviewer-${review_count}.log" 2>/dev/null; then
                        log "Tests failing at final drain — triggering orchestrator to add fix tasks"
                        local next_num
                        next_num=$(compute_next_task_num)
                        docker_run_orchestrator "$next_num"
                        # If orchestrator added no tasks, there's nothing more to do
                        if [[ "$(pending_count)" -eq 0 ]]; then
                            warn "Tests failing but orchestrator added no fix tasks — forcing stop"
                            all_complete=true
                        fi
                    else
                        # No test signal (no test suite yet) — treat as complete
                        log "No test result from final reviewer — assuming project complete"
                        all_complete=true
                    fi
                fi
            elif [[ "$p_count" -gt 0 && "$a_count" -eq 0 ]]; then
                # Pending tasks exist but no worker is active — potential deadlock
                stuck_cycles=$((stuck_cycles + 1))
                if [[ "$stuck_cycles" -ge "$max_stuck_cycles" ]]; then
                    review_count=$((review_count + 1))
                    if [[ "$review_count" -gt "$max_reviews" ]]; then
                        warn "Max reviews ($max_reviews) reached — forcing stop"
                        all_complete=true
                    else
                        log "Stuck state detected (${stuck_cycles} idle cycles) — triggering orchestrator (${review_count})..."
                        local next_num
                        next_num=$(compute_next_task_num)
                        docker_run_orchestrator "$next_num"
                        stuck_cycles=0
                    fi
                fi
            else
                stuck_cycles=0
            fi
        else
            stuck_cycles=0
        fi

        if [[ "$all_complete" == "false" ]]; then
            local p a d
            p=$(pending_count)
            a=$(active_count)
            d=$(done_count)
            log "Review loop: ${d} done | ${a} active | ${p} pending | ${#reviewed[@]} reviewed"
        fi
    done

    kill "$monitor_pid" 2>/dev/null || true
    cleanup_docker
}

cleanup_docker() {
    if [[ -n "$RUN_ID" ]]; then
        docker ps -q --filter "name=swarm-${RUN_ID}-" 2>/dev/null | xargs -r docker stop 2>/dev/null || true
        docker ps -aq --filter "name=swarm-${RUN_ID}-" 2>/dev/null | xargs -r docker rm 2>/dev/null || true
    fi
}

# ─────────────────────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────────────────────

# Count .md files in a dir (safe: returns 0 when empty or missing)
count_files() {
    local dir="$1"
    find "$dir" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ' || echo 0
}

sync_main() {
    (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true
    sync_remote
}

# Push local bare repo to remote GitHub repo (no-op if --repo not set)
sync_remote() {
    [[ -z "$REMOTE_REPO" ]] && return 0
    (cd "$REPO_DIR" && git push github --all -q 2>/dev/null) || true
}

pending_count() { count_files "$MAIN_DIR/tasks/pending"; }
active_count()  { count_files "$MAIN_DIR/tasks/active"; }
done_count()    { count_files "$MAIN_DIR/tasks/done"; }

# ─────────────────────────────────────────────────────────────
# WORKSPACE INITIALIZATION
# ─────────────────────────────────────────────────────────────

init_workspace() {
    log "Creating workspace: $OUTPUT_DIR"
    mkdir -p "$LOGS_DIR"

    if [[ -n "$REMOTE_REPO" ]]; then
        # Clone remote repo as local bare mirror for fast coordination
        log "Cloning remote repo: $REMOTE_REPO"
        git clone --bare "$REMOTE_REPO" "$REPO_DIR" -q 2>/dev/null || {
            # Remote may be empty — init locally and add remote
            mkdir -p "$REPO_DIR"
            git init --bare "$REPO_DIR" -q
            (cd "$REPO_DIR" && git remote add github "$REMOTE_REPO")
        }
        # Ensure github remote is set (clone --bare names it 'origin')
        (cd "$REPO_DIR" && git remote get-url github 2>/dev/null) || \
            (cd "$REPO_DIR" && git remote add github "$REMOTE_REPO") || true
    else
        mkdir -p "$REPO_DIR"
        git init --bare "$REPO_DIR" -q
    fi

    # Bootstrap with initial structure
    local bootstrap_dir
    bootstrap_dir=$(mktemp -d)
    git clone "$REPO_DIR" "$bootstrap_dir" -q 2>/dev/null

    (
        cd "$bootstrap_dir"
        git config user.email "swarm@local"
        git config user.name "Swarm"

        mkdir -p tasks/pending tasks/active tasks/done
        # Git doesn't track empty dirs — .gitkeep ensures workers get all task dirs
        touch tasks/pending/.gitkeep tasks/active/.gitkeep tasks/done/.gitkeep

        cat > SPEC.md <<SPECEOF
# Project Specification

**Task:** $TASK

*The orchestrator agent will replace this with a full specification.*
SPECEOF

        cat > PROGRESS.md <<PROGEOF
# Progress

**Task:** $TASK
**Status:** INITIALIZING

*Updated by agents as work progresses.*
PROGEOF

        git add -A
        git commit -m "init: workspace bootstrap" -q
        git push origin main -q
    )

    rm -rf "$bootstrap_dir"

    # Push bootstrap to remote
    sync_remote

    # Clone the "main" view (read results here)
    git clone "$REPO_DIR" "$MAIN_DIR" -q 2>/dev/null
    (
        cd "$MAIN_DIR"
        git config user.email "swarm@local"
        git config user.name "Swarm"
    )

    success "Workspace ready"
}

# ─────────────────────────────────────────────────────────────
# PROGRESS MONITOR (background)
# ─────────────────────────────────────────────────────────────

monitor_progress() {
    local interval=15
    while true; do
        sleep $interval
        sync_main 2>/dev/null || true
        local p a d
        p=$(pending_count)
        a=$(active_count)
        d=$(done_count)
        log "Progress: ${GREEN}${d} done${NC} | ${YELLOW}${a} active${NC} | ${BLUE}${p} pending${NC}"
    done
}

# ─────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────

main() {
    # Check prerequisites
    if ! command -v git &>/dev/null; then
        error "git not found. Please install git."
        exit 1
    fi
    if ! command -v docker &>/dev/null; then
        error "Docker not found. Install Docker."
        exit 1
    fi

    # Determine mode: new run vs resume
    local is_resume=false
    if [[ -d "$OUTPUT_DIR/main/tasks" ]]; then
        is_resume=true
        # Load state from existing run
        local state_file="$OUTPUT_DIR/swarm.state"
        if [[ -f "$state_file" ]]; then
            # shellcheck source=/dev/null
            source "$state_file"
            # CLI flags override saved state; saved state fills gaps
            [[ -z "$MODEL" && -n "${SWARM_MODEL:-}" ]] && MODEL="$SWARM_MODEL"
            [[ -z "$REMOTE_REPO" && -n "${SWARM_REPO:-}" ]] && REMOTE_REPO="$SWARM_REPO"
        fi
    fi

    RUN_ID="$(basename "$OUTPUT_DIR")"
    REPO_DIR="$OUTPUT_DIR/repo.git"
    LOGS_DIR="$OUTPUT_DIR/logs"
    MAIN_DIR="$OUTPUT_DIR/main"

    # Ensure github remote is configured if --repo was provided
    if [[ -n "$REMOTE_REPO" && -d "$REPO_DIR" ]]; then
        (cd "$REPO_DIR" && git remote get-url github 2>/dev/null) || \
            (cd "$REPO_DIR" && git remote add github "$REMOTE_REPO") || true
    fi

    # Banner
    echo
    echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║       🐝  SWARM FRAMEWORK  🐝            ║${NC}"
    echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
    echo
    info "Prompt: $TASK"
    info "Agents: $NUM_AGENTS"
    [[ -n "$MODEL" ]] && info "Model:  $MODEL"
    [[ -n "$REMOTE_REPO" ]] && info "Repo:   $REMOTE_REPO"
    info "Output: $OUTPUT_DIR"
    [[ "$is_resume" == "true" ]] && info "Mode:   resume"
    echo

    # Warn about running containers from prior swarm runs
    local prior_count
    prior_count=$(docker ps -q --filter "name=swarm-" 2>/dev/null | wc -l | tr -d ' ') || prior_count=0
    if [[ "$prior_count" -gt 0 ]]; then
        warn "$prior_count swarm container(s) from a prior run are still running — run './swarm cleanup' to stop them"
    fi

    # Build Docker image
    ensure_docker_image
    trap cleanup_docker EXIT
    echo

    if [[ "$is_resume" == "true" ]]; then
        # ── RESUME: unstick tasks, inject new guidance, run workers ──

        # Pull latest state
        (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

        # Return any stuck tasks back to pending
        local unstick_dir
        unstick_dir=$(mktemp -d)
        git clone "$REPO_DIR" "$unstick_dir" -q 2>/dev/null
        (
            cd "$unstick_dir"
            git config user.email "swarm@local"
            git config user.name "Swarm Resume"
            local any_moved=false
            for sf in tasks/active/worker-*.md; do
                if [[ -f "$sf" ]]; then
                    local tname
                    tname=$(basename "$sf" | sed 's/worker-[^-]*--//')
                    log "  Returning stuck task: $tname"
                    mv "$sf" "tasks/pending/$tname"
                    any_moved=true
                fi
            done
            if [[ "$any_moved" == "true" ]]; then
                git add -A
                git commit -m "resume: return stuck tasks to pending" -q
                git push origin main -q
            fi
        )
        rm -rf "$unstick_dir"

        # Sync main view
        (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

        # Augment project if the prompt differs from the original task
        local original_task="${SWARM_TASK:-}"
        if [[ -n "$TASK" && "$TASK" != "$original_task" ]]; then
            log "Augmenting project with new guidance..."
            local max_num=0 f num
            for f in "$MAIN_DIR/tasks/pending/"*.md \
                      "$MAIN_DIR/tasks/active/"*.md \
                      "$MAIN_DIR/tasks/done/"*.md; do
                [[ -f "$f" ]] || continue
                num=$(basename "$f" | grep -o '^[0-9]*' || echo 0)
                num=$((10#$num))
                [[ "$num" -gt "$max_num" ]] && max_num="$num"
            done
            local next_num=$(( max_num + 1 ))
            docker_run_orchestrator "$next_num"
            (cd "$MAIN_DIR" && git pull origin main -q 2>/dev/null) || true

            # Specialist sweep after augmentation — validate new tasks
            _g_specialist_count=0
            run_specialist_sweep "post-augment"
            sync_main
            echo
        fi

        local pending done_n
        pending=$(pending_count)
        done_n=$(done_count)

        if [[ "$pending" -eq 0 ]]; then
            success "Nothing to do — all tasks already complete ($done_n done)"
            echo
            return 0
        fi

        success "$pending task(s) pending, $done_n done — spawning $NUM_AGENTS worker(s)"
        echo
    else
        # ── NEW RUN: init workspace, orchestrate, pre-flight sweep ──

        init_workspace
        echo

        # Write state file
        {
            printf 'SWARM_TASK=%q\n' "$TASK"
            printf 'SWARM_AGENTS=%s\n' "$NUM_AGENTS"
            printf 'SWARM_MODEL=%q\n' "$MODEL"
            printf 'SWARM_REPO=%q\n' "$REMOTE_REPO"
            printf 'SWARM_STARTED="%s"\n' "$(date)"
        } > "$OUTPUT_DIR/swarm.state"

        # Run orchestrator
        if ! docker_run_orchestrator; then
            error "Orchestration failed."
            exit 1
        fi
        echo

        # Pre-flight specialist sweep
        _g_specialist_count=0
        run_specialist_sweep "pre-flight"
        sync_main
        echo

        log "Spawning $NUM_AGENTS worker agents..."
        echo
    fi

    # ── Common: run workers with review loop ──

    _g_specialist_count="${_g_specialist_count:-0}"
    run_with_review "$NUM_AGENTS"

    # Final sync
    sync_main 2>/dev/null || true

    local total_done total_pending total_active
    total_done=$(done_count)
    total_pending=$(pending_count)
    total_active=$(active_count)

    echo
    echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║                RESULTS                   ║${NC}"
    echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
    echo

    success "Tasks completed:  $total_done"
    if [[ "$total_pending" -gt 0 ]]; then warn "Tasks incomplete: $total_pending"; fi
    if [[ "$total_active"  -gt 0 ]]; then warn "Tasks stuck:      $total_active"; fi
    echo
    info "Project files: $MAIN_DIR/"
    info "Agent logs:    $LOGS_DIR/"
    echo

    if [[ "$total_done" -eq 0 ]]; then
        error "No tasks completed. Check logs in $LOGS_DIR/"
        exit 1
    fi

    if [[ "${failed:-0}" -gt 0 ]]; then warn "${failed} worker(s) exited with errors (check logs)"; fi

    success "Swarm complete! 🐝"
    echo
}

# ─────────────────────────────────────────────────────────────
# PARSE ARGUMENTS  (guarded so script can be sourced for testing)
# ─────────────────────────────────────────────────────────────

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then

# Check for subcommands first
case "${1:-}" in
    status)
        shift
        cmd_status "${1:-}"
        exit 0
        ;;
    logs)
        shift
        cmd_logs "${1:-}" "${2:-}"
        exit 0
        ;;
    kill)
        shift
        cmd_kill "${1:-}" "${2:-}"
        exit 0
        ;;
    cleanup)
        shift
        cmd_cleanup "${1:-}"
        exit 0
        ;;
esac

while [[ $# -gt 0 ]]; do
    case $1 in
        -n|--agents)        NUM_AGENTS="$2"; shift 2 ;;
        -o|--output)        OUTPUT_DIR="$2"; shift 2 ;;
        -v|--verbose)       VERBOSE=true; shift ;;
        --model)            MODEL="$2"; shift 2 ;;
        --repo)             REMOTE_REPO="$2"; shift 2 ;;
        --mount)            EXTRA_MOUNTS+=("$2"); shift 2 ;;
        --max-iterations)   MAX_WORKER_ITERATIONS="$2"; shift 2 ;;
        -h|--help)      usage; exit 0 ;;
        -*)             error "Unknown option: $1"; usage; exit 1 ;;
        *)              TASK="${TASK:+$TASK }$1"; shift ;;
    esac
done

# Prompt is required for new runs; optional for resume (just point -o at existing dir)
if [[ -z "$TASK" ]]; then
    if [[ -n "$OUTPUT_DIR" && -d "$OUTPUT_DIR/main/tasks" ]]; then
        TASK=""  # Resume with no new guidance
    else
        error "No prompt specified."; echo; usage; exit 1
    fi
fi
[[ -z "$OUTPUT_DIR" ]] && OUTPUT_DIR="./swarm-$(date +%Y%m%d-%H%M%S)"

# Resolve to absolute path
OUTPUT_DIR="$(cd "$(dirname "$OUTPUT_DIR")" 2>/dev/null && pwd)/$(basename "$OUTPUT_DIR")" || OUTPUT_DIR="$(pwd)/$(basename "$OUTPUT_DIR")"

fi # end BASH_SOURCE guard for argument parsing

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then main "$@"; fi
